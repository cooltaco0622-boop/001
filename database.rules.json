{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['people', 'expenses', 'updatedAt'])"
      }
    },
    "archives": {
      "$archiveId": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['id', 'name', 'createdAt', 'people', 'expenses'])"
      }
    }
  }
}
